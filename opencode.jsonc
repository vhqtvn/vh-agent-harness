                    "git ls-files *": "allow",
                    "git show-ref *": "allow",
                    "git rev-parse *": "allow",
                    "git check-ignore *": "allow",
                    ".opencode/scripts/readonly-scripts.sh *": "allow",
                    "vh-agent-harness *": "allow"
                },
                "edit": "allow",
                "skill": {
                    "*": "allow"
                },
                "task": {
                    "*": "deny",
                    "project-coordinator": "allow",
                    "planner": "allow",
                    "researcher": "allow",
                    "repo-explorer": "allow",
                    "ship-review": "allow",
                    "docs-steward": "allow"
                },
                "webfetch": "allow"
            },
            "prompt": "{file:.opencode/agents/build.md}"
        },
