            "model": "{file:./.local/config/agent-model/build}",
            "permission": {
                "bash": {
                    "*": "ask",
                    "jq *": "allow",
                    "ls *": "allow",
                    "rg *": "allow",
                    "wc *": "allow",
                    "cat *": "allow",
                    "cut *": "allow",
