                    ".opencode/scripts/readonly-scripts.sh *": "allow",
                    "vh-agent-harness *": "allow"
                },
                "edit": "allow",
                "skill": {
                    "*": "allow"
                },
                "task": {
                    "*": "deny",
                    "project-coordinator": "allow",
                    "planner": "allow",
                    "researcher": "allow",
                    "repo-explorer": "allow",
                    "ship-review": "allow",
