{
    "$schema": "https://opencode.ai/config.json",
    "agent": {
        "build": {
            "color": "success",
            "description": "Default primary agent for day-to-day work. Asks before edits and editable specialist handoffs.",
            "mode": "all",
            "model": "{file:./.local/config/agent-model/build}",
            "permission": {
                "bash": {
                    "*": "ask",
                    "jq *": "allow",
                    "ls *": "allow",
                    "rg *": "allow",
                    "wc *": "allow",
                    "cat *": "allow",
                    "cut *": "allow",
                    "date *": "allow",
                    "echo *": "allow",
                    "find *": "allow",
                    "grep *": "allow",
                    "head *": "allow",
                    "sort *": "allow",
                    "tail *": "allow",
                    "true *": "allow",
                    "uniq *": "allow",
                    "sleep *": "allow",
                    "printf *": "allow",
                    "sed -n *": "allow",
                    "git log *": "allow",
                    "git diff *": "allow",
                    "git grep *": "allow",
                    "git show *": "allow",
                    "git blame *": "allow",
                    "git status *": "allow",
