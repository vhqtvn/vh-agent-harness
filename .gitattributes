# Normalize line endings — checkout LF, commit LF.
* text=auto eol=lf

# Source files
*.go   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.sh   text eol=lf
*.mod  text eol=lf
*.sum  text eol=lf

# Binary assets — never normalize
*.wasm binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.zip  binary
*.gz   binary
*.pdf  binary
